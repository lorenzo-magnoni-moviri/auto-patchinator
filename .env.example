# Copy to .env and fill in. This file is gitignored - never commit .env.
# If both vars are set, auto-patchinator skips the credential prompt on startup.
# Omit either var to be prompted for it instead.
#
# chmod 600 .env  after creating it.

AP_USERNAME=your_ldap_username
AP_PASSWORD=your_pas_password

# Optional: Splunk REST API credentials for FUTURE automations only (search-head
# captain transfer/revert, cluster status polling - see TODO.md). Nothing in the tool
# reads these yet; leave unset until those features are built. Prefer a token over
# username/password if your Splunk deployment issues one.
# NEVER hardcode these values in source or commit history - only via this file.
SPLUNK_API_TOKEN=
SPLUNK_API_USER=
SPLUNK_API_PASSWORD=
